{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",

  "productName": "ROK Companion",
  "version":     "0.1.0",
  "identifier":  "com.rokcompanion.companion",

  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl":             "http://localhost:1420",
    "frontendDist":       "../dist"
  },

  "app": {
    "withGlobalTauri": true,

    "windows": [
      {
        "label":      "main",
        "title":      "ROK Companion",
        "width":      440,
        "height":     620,
        "minWidth":   380,
        "minHeight":  480,
        "resizable":  true,
        "fullscreen": false,
        "decorations": true,
        "center":     true,
        "visible":    true
      }
    ],

    "security": {
      "csp": null
    },

    "trayIcon": {
      "iconPath":       "icons/32x32.png",
      "iconAsTemplate": true
    }
  },

  "bundle": {
    "active":  true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],

    "externalBin": [
      "binaries/RoKScreenReader"
    ],

    "macOS": {
      "entitlements":         "entitlements.plist",
      "minimumSystemVersion": "14.0"
    },
    "category": "Utilities"
  }
}
