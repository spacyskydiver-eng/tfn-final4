// Prisma schema for the ROK Kill Tracker system.
// Run `pnpm prisma migrate dev --name init` after setting DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ─────────────────────────────────────────────────────────────────────
// Mirrors the Discord OAuth user stored in the session layer.
// Upserted on every login so it stays in sync with Discord.
model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  username  String
  avatar    String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiTokens  ApiToken[]
  killEvents KillEvent[]
  commanderSubmissions CommanderSubmission[]
  kvkSetups  KvkSetup[]
  orders     Order[]
}

// ─── ApiToken ─────────────────────────────────────────────────────────────────
// Per-user tokens issued to the macOS companion app.
// The raw token (rok_<64 hex chars>) is shown ONCE and never stored here —
// only the SHA-256 hash is persisted so a database breach cannot expose tokens.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String    // Friendly label the user gives the device, e.g. "MacBook Pro"
  tokenHash  String    @unique // SHA-256(rawToken) — used for constant-time lookup
  lastUsedAt DateTime? // Updated every time the token successfully authenticates
  createdAt  DateTime  @default(now())
  revokedAt  DateTime? // null = active; non-null = revoked

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── KillEvent ────────────────────────────────────────────────────────────────
// One parsed battle report submitted by the companion app via clipboard.
// Duplicate prevention: a user cannot submit the same content hash twice.
model KillEvent {
  id          String   @id @default(cuid())
  userId      String

  // Parser output
  reportType  String   // "BARBARIAN_KILL" | "FORT_KILL" | "UNKNOWN"
  rawText     String   @db.Text // Full original copied report text
  contentHash String   // SHA-256(normalise(rawText)) — dedup key

  // Structured parsed fields stored as JSON for flexibility
  parsedData  Json

  // Denormalised counters for fast aggregate queries
  killCount   Int      @default(0) // Total enemy unit deaths
  fortKills   Int      @default(0) // Forts/structures destroyed

  syncedVia   String   @default("clipboard") // "clipboard" | "manual"
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One user cannot submit the exact same report twice
  @@unique([userId, contentHash])
  @@index([userId, reportType])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── CommanderSubmission ──────────────────────────────────────────────────────
// A commander build shared in kingdom chat, captured by the bot.
// One row per unique (player + commander + snapshot).
model CommanderSubmission {
  id              String   @id @default(cuid())
  userId          String   // API token owner (the bot operator)
  contentHash     String   // SHA-256(commanderName+sharedByPlayer+stars+level) — dedup

  // Who shared it
  sharedByPlayer  String

  // Commander identity
  commanderName   String
  commanderTitle  String?

  // Stats visible on profile screen
  stars           Int?
  level           Int?
  skillLevel      Int?   // secondary level (the /10 part)
  commanderPower  Int?

  // Skills (levels of each of the 5 skills)
  skillLevels     Json?  // e.g. [5, 5, 5, 5, 4]

  // Formation & armament
  formationName   String?
  armamentSet     String?
  armamentStats   Json?  // e.g. ["Cavalry Attack +8.9%", "Cavalry Defense +9.3%"]

  // Equipment (identified item names per slot, if recognisable)
  equipment       Json?  // e.g. { head: "...", chest: "...", ... }

  // Raw OCR dumps from each screen (for reprocessing later)
  rawProfileText   String? @db.Text
  rawEquipText     String? @db.Text
  rawFormationText String? @db.Text

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentHash])
  @@index([userId, createdAt(sort: Desc)])
  @@index([commanderName])
  @@map("commander_submissions")
}

// ─── KvkSetup ─────────────────────────────────────────────────────────────────
// A KvK tracking contract created by a customer.
// Staff are notified via Discord when one is created, then set it live.
model KvkSetup {
  id          String   @id @default(cuid())
  createdById String   // User who purchased/created this KvK
  name        String   // e.g. "Heroic Anthem #C13093"
  kvkType     String   // heroic-anthem | tides-of-war | warriors-unbound | etc.
  isSoC       Boolean  @default(true)
  bundle      String   // full-kvk | two-camp | one-camp
  status      String   @default("pending") // pending | active | paused | completed

  // Date range for this KvK
  startDate   DateTime?
  endDate     DateTime?

  // DKP formula weights (overridable by leadership)
  dkpDeadWeight Float @default(12)
  dkpT4Weight   Float @default(4)
  dkpT5Weight   Float @default(8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Staff assignment & task tracking
  assignedToId    String?
  assignedToName  String?
  assignedAt      DateTime?
  completedAt     DateTime?
  completedById   String?
  completedByName String?

  // Linked purchase order (set when user creates KvK after buying)
  orderId         String?

  createdBy     User             @relation(fields: [createdById], references: [id])
  kingdoms      KvkKingdom[]
  playerGoals   KvkPlayerGoal[]
  scanSchedules ScanSchedule[]

  @@index([createdById])
  @@index([status])
  @@map("kvk_setups")
}

// ─── KvkKingdom ───────────────────────────────────────────────────────────────
// A participating kingdom in a KvK.
model KvkKingdom {
  id        String  @id @default(cuid())
  kvkId     String
  kdNumber  String  // e.g. "3517"
  camp      String  // Fire | Earth | Water | Wind | etc.
  tracked   Boolean @default(true) // false = map-only, not bot-scanned

  kvk KvkSetup @relation(fields: [kvkId], references: [id], onDelete: Cascade)

  @@unique([kvkId, kdNumber])
  @@index([kvkId])
  @@map("kvk_kingdoms")
}

// ─── KvkPlayerGoal ────────────────────────────────────────────────────────────
// DKP and kill goals set by kingdom leadership for individual players.
model KvkPlayerGoal {
  id         String  @id @default(cuid())
  kvkId      String
  govId      String  // In-game governor ID
  playerName String
  alliance   String?

  dkpGoal     Float?  // Target DKP score
  t4KillGoal  Float?  // Target T4 kills
  t5KillGoal  Float?  // Target T5 kills
  deadGoal    Float?  // Target deaths (for farming DKP)
  honorGoal   Float?  // Target honor points

  setById   String   // User ID of who set this goal
  updatedAt DateTime @updatedAt

  kvk KvkSetup @relation(fields: [kvkId], references: [id], onDelete: Cascade)

  @@unique([kvkId, govId])
  @@index([kvkId])
  @@map("kvk_player_goals")
}

// ─── Order ────────────────────────────────────────────────────────────────────
// A purchase order created when a user checks out from the Bot Tools store.
// Generates a unique product key the user redeems in Discord to open a ticket.
model Order {
  id          String   @id @default(cuid())
  userId      String
  productKey  String   @unique // e.g. "TFN-A1B2-C3D4-E5F6"

  // All cart items bundled into one order
  items       Json?    // [{toolId, label, bundle?, isSoC?, price}]
  totalUsd    Float?   // sum of all item prices

  // Legacy single-item fields (null for multi-item orders)
  toolType    String?
  bundle      String?
  isSoC       Boolean?
  priceUsd    Float?

  // Lifecycle
  status      String   @default("pending") // pending | confirmed | active | cancelled

  // Set by staff after payment confirmed
  confirmedById String?
  confirmedAt   DateTime?

  // Linked KvK setup once staff creates it
  kvkSetupId  String?

  notes       String?  @db.Text // staff notes

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([productKey])
  @@map("orders")
}

// ─── ScanSchedule ─────────────────────────────────────────────────────────────
// When and what the bot should scan for a given KvK.
model ScanSchedule {
  id          String   @id @default(cuid())
  kvkId       String
  label       String   // e.g. "Daily Morning Scan"
  cronExpr    String   // cron syntax, e.g. "0 6 * * *" = 06:00 UTC daily
  scanType    String   // dkp | honor | pre-kvk | seeding | all
  topN        Int      @default(300) // How many players to scan (100-1000)
  enabled     Boolean  @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())

  kvk KvkSetup @relation(fields: [kvkId], references: [id], onDelete: Cascade)

  @@index([kvkId])
  @@map("scan_schedules")
}

// ─── Discord Verification Service ─────────────────────────────────────────────

model VerificationServer {
  id             String   @id @default(cuid())
  guildId        String   @unique
  guildName      String
  channelId      String?  // verification channel ID to watch
  staffRoleId    String?  // role to ping on failure
  freeLimit      Int      @default(250)  // monthly free verifications; -1 = unlimited
  usedCount      Int      @default(0)
  addedById      String   // DB user cuid who registered it
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rules VerificationRule[]
  logs  VerificationLog[]

  @@map("verification_servers")
}

model VerificationRule {
  id          String @id @default(cuid())
  serverId    String
  allianceTag String   // e.g. "[T13O]" or "T13O" — matched case-insensitively
  roleId      String   // Discord role ID to assign when match
  label       String?  // friendly label e.g. "Twilight of Order"

  server VerificationServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@map("verification_rules")
}

model VerificationLog {
  id              String   @id @default(cuid())
  serverId        String
  guildId         String
  discordUserId   String
  discordUsername String
  govId           String?
  govName         String?
  allianceTag     String?  // extracted from image
  result          String   // success | failed_alliance | already_used | parse_failed | over_limit
  roleAssigned    String?  // Discord role ID if assigned
  roleName        String?  // role label for display
  createdAt       DateTime @default(now())

  server VerificationServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([govId, serverId])
  @@index([discordUserId, serverId])
  @@map("verification_logs")
}
