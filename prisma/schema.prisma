// Prisma schema for the ROK Kill Tracker system.
// Run `pnpm prisma migrate dev --name init` after setting DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ─────────────────────────────────────────────────────────────────────
// Mirrors the Discord OAuth user stored in the session layer.
// Upserted on every login so it stays in sync with Discord.
model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  username  String
  avatar    String?
  isAdmin      Boolean  @default(false)
  isLeadership Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiTokens  ApiToken[]
  killEvents KillEvent[]
  commanderSubmissions CommanderSubmission[]
  kvkSetups  KvkSetup[]
  orders     Order[]
  arkEvents ArkEvent[] @relation("UserArkEvents")
  arkForms  ArkForm[]  @relation("UserArkForms")
}

// ─── ApiToken ─────────────────────────────────────────────────────────────────
// Per-user tokens issued to the macOS companion app.
// The raw token (rok_<64 hex chars>) is shown ONCE and never stored here —
// only the SHA-256 hash is persisted so a database breach cannot expose tokens.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String    // Friendly label the user gives the device, e.g. "MacBook Pro"
  tokenHash  String    @unique // SHA-256(rawToken) — used for constant-time lookup
  lastUsedAt DateTime? // Updated every time the token successfully authenticates
  createdAt  DateTime  @default(now())
  revokedAt  DateTime? // null = active; non-null = revoked

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── KillEvent ────────────────────────────────────────────────────────────────
// One parsed battle report submitted by the companion app via clipboard.
// Duplicate prevention: a user cannot submit the same content hash twice.
model KillEvent {
  id          String   @id @default(cuid())
  userId      String

  // Parser output
  reportType  String   // "BARBARIAN_KILL" | "FORT_KILL" | "UNKNOWN"
  rawText     String   @db.Text // Full original copied report text
  contentHash String   // SHA-256(normalise(rawText)) — dedup key

  // Structured parsed fields stored as JSON for flexibility
  parsedData  Json

  // Denormalised counters for fast aggregate queries
  killCount   Int      @default(0) // Total enemy unit deaths
  fortKills   Int      @default(0) // Forts/structures destroyed

  syncedVia   String   @default("clipboard") // "clipboard" | "manual"
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One user cannot submit the exact same report twice
  @@unique([userId, contentHash])
  @@index([userId, reportType])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── CommanderSubmission ──────────────────────────────────────────────────────
// A commander build shared in kingdom chat, captured by the bot.
// One row per unique (player + commander + snapshot).
model CommanderSubmission {
  id              String   @id @default(cuid())
  userId          String   // API token owner (the bot operator)
  contentHash     String   // SHA-256(commanderName+sharedByPlayer+stars+level) — dedup

  // Who shared it
  sharedByPlayer  String

  // Commander identity
  commanderName   String
  commanderTitle  String?

  // Stats visible on profile screen
  stars           Int?
  level           Int?
  skillLevel      Int?   // secondary level (the /10 part)
  commanderPower  Int?

  // Skills (levels of each of the 5 skills)
  skillLevels     Json?  // e.g. [5, 5, 5, 5, 4]

  // Formation & armament
  formationName   String?
  armamentSet     String?
  armamentStats   Json?  // e.g. ["Cavalry Attack +8.9%", "Cavalry Defense +9.3%"]

  // Equipment (identified item names per slot, if recognisable)
  equipment       Json?  // e.g. { head: "...", chest: "...", ... }

  // Raw OCR dumps from each screen (for reprocessing later)
  rawProfileText   String? @db.Text
  rawEquipText     String? @db.Text
  rawFormationText String? @db.Text

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentHash])
  @@index([userId, createdAt(sort: Desc)])
  @@index([commanderName])
  @@map("commander_submissions")
}

// ─── KvkSetup ─────────────────────────────────────────────────────────────────
// A KvK tracking contract created by a customer.
// Staff are notified via Discord when one is created, then set it live.
model KvkSetup {
  id          String   @id @default(cuid())
  createdById String   // User who purchased/created this KvK
  name        String   // e.g. "Heroic Anthem #C13093"
  kvkType     String   // heroic-anthem | tides-of-war | warriors-unbound | etc.
  isSoC       Boolean  @default(true)
  bundle      String   // full-kvk | two-camp | one-camp
  status      String   @default("pending") // pending | active | paused | completed

  // Date range for this KvK
  startDate   DateTime?
  endDate     DateTime?

  // DKP formula weights (overridable by leadership)
  dkpDeadWeight Float @default(12)
  dkpT4Weight   Float @default(4)
  dkpT5Weight   Float @default(8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Staff assignment & task tracking
  assignedToId    String?
  assignedToName  String?
  assignedAt      DateTime?
  completedAt     DateTime?
  completedById   String?
  completedByName String?

  // Linked purchase order (set when user creates KvK after buying)
  orderId         String?

  createdBy     User             @relation(fields: [createdById], references: [id])
  kingdoms      KvkKingdom[]
  playerGoals   KvkPlayerGoal[]
  scanSchedules ScanSchedule[]

  @@index([createdById])
  @@index([status])
  @@map("kvk_setups")
}

// ─── KvkKingdom ───────────────────────────────────────────────────────────────
// A participating kingdom in a KvK.
model KvkKingdom {
  id        String  @id @default(cuid())
  kvkId     String
  kdNumber  String  // e.g. "3517"
  camp      String  // Fire | Earth | Water | Wind | etc.
  tracked   Boolean @default(true) // false = map-only, not bot-scanned

  kvk KvkSetup @relation(fields: [kvkId], references: [id], onDelete: Cascade)

  @@unique([kvkId, kdNumber])
  @@index([kvkId])
  @@map("kvk_kingdoms")
}

// ─── KvkPlayerGoal ────────────────────────────────────────────────────────────
// DKP and kill goals set by kingdom leadership for individual players.
model KvkPlayerGoal {
  id         String  @id @default(cuid())
  kvkId      String
  govId      String  // In-game governor ID
  playerName String
  alliance   String?

  dkpGoal     Float?  // Target DKP score
  t4KillGoal  Float?  // Target T4 kills
  t5KillGoal  Float?  // Target T5 kills
  deadGoal    Float?  // Target deaths (for farming DKP)
  honorGoal   Float?  // Target honor points

  setById   String   // User ID of who set this goal
  updatedAt DateTime @updatedAt

  kvk KvkSetup @relation(fields: [kvkId], references: [id], onDelete: Cascade)

  @@unique([kvkId, govId])
  @@index([kvkId])
  @@map("kvk_player_goals")
}

// ─── Order ────────────────────────────────────────────────────────────────────
// A purchase order created when a user checks out from the Bot Tools store.
// Generates a unique product key the user redeems in Discord to open a ticket.
model Order {
  id          String   @id @default(cuid())
  userId      String
  productKey  String   @unique // e.g. "TFN-A1B2-C3D4-E5F6"

  // All cart items bundled into one order
  items       Json?    // [{toolId, label, bundle?, isSoC?, price}]
  totalUsd    Float?   // sum of all item prices

  // Legacy single-item fields (null for multi-item orders)
  toolType    String?
  bundle      String?
  isSoC       Boolean?
  priceUsd    Float?

  // Lifecycle
  status      String   @default("pending") // pending | confirmed | active | cancelled

  // Set by staff after payment confirmed
  confirmedById String?
  confirmedAt   DateTime?

  // Linked KvK setup once staff creates it
  kvkSetupId  String?

  notes       String?  @db.Text // staff notes

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([productKey])
  @@map("orders")
}

// ─── ScanSchedule ─────────────────────────────────────────────────────────────
// When and what the bot should scan for a given KvK.
model ScanSchedule {
  id          String   @id @default(cuid())
  kvkId       String
  label       String   // e.g. "Daily Morning Scan"
  cronExpr    String   // cron syntax, e.g. "0 6 * * *" = 06:00 UTC daily
  scanType    String   // dkp | honor | pre-kvk | seeding | all
  topN        Int      @default(300) // How many players to scan (100-1000)
  enabled     Boolean  @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())

  kvk KvkSetup @relation(fields: [kvkId], references: [id], onDelete: Cascade)

  @@index([kvkId])
  @@map("scan_schedules")
}

// ─── Discord Verification Service ─────────────────────────────────────────────

model VerificationServer {
  id             String   @id @default(cuid())
  guildId        String   @unique
  guildName      String
  channelId      String?  // verification channel ID to watch
  staffRoleId    String?  // role to ping on failure
  freeLimit      Int      @default(150)  // free verification limit per server; -1 = unlimited
  usedCount      Int      @default(0)
  addedById      String   // DB user cuid who registered it
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rules VerificationRule[]
  logs  VerificationLog[]

  @@map("verification_servers")
}

model VerificationRule {
  id          String @id @default(cuid())
  serverId    String
  allianceTag String   // e.g. "[T13O]" or "T13O" — matched case-insensitively
  roleId      String   // Discord role ID to assign when match
  label       String?  // friendly label e.g. "Twilight of Order"

  server VerificationServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@map("verification_rules")
}

model VerificationLog {
  id              String   @id @default(cuid())
  serverId        String
  guildId         String
  discordUserId   String
  discordUsername String
  govId           String?
  govName         String?
  allianceTag     String?  // extracted from image
  result          String   // success | failed_alliance | already_used | parse_failed | over_limit
  roleAssigned    String?  // Discord role ID if assigned
  roleName        String?  // role label for display
  createdAt       DateTime @default(now())

  server VerificationServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([govId, serverId])
  @@index([discordUserId, serverId])
  @@map("verification_logs")
}

// ─── SiteConfig ────────────────────────────────────────────────────────────────
// Generic key/value store for admin-managed site-wide settings (e.g. bundle data).
model SiteConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("site_config")
}

// ─── Ark of Osiris ────────────────────────────────────────────────────────────

// Alliance roster synced from bot — govId is the unique key
model ArkPlayer {
  id              String   @id @default(cuid())
  govId           String   @unique
  govName         String
  allianceTag     String?
  power           BigInt?
  discordId       String?
  discordVerified Boolean  @default(false)
  arkExperience   Boolean  @default(false)
  troopT4         BigInt?
  troopT5         BigInt?
  rallyCapacity   BigInt?
  extraData       Json?
  botUpdatedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([allianceTag])
  @@map("ark_players")
}

model ArkEvent {
  id             String    @id @default(cuid())
  name           String
  description    String?
  scheduledAt    DateTime?
  status         String    @default("planning")
  discordWebhook String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdBy User      @relation("UserArkEvents", fields: [createdById], references: [id])
  form      ArkForm?
  teams     ArkTeam[]

  @@index([status])
  @@map("ark_events")
}

model ArkForm {
  id          String   @id @default(cuid())
  eventId     String?  @unique
  shortCode   String   @unique
  title       String
  description String?
  isOpen      Boolean  @default(true)
  guildId                    String?
  guildName                  String?
  requireDiscordVerification Boolean @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event     ArkEvent?         @relation(fields: [eventId], references: [id])
  createdBy User              @relation("UserArkForms", fields: [createdById], references: [id])
  questions ArkFormQuestion[]
  responses ArkResponse[]

  @@map("ark_forms")
}

model ArkFormQuestion {
  id          String  @id @default(cuid())
  formId      String
  order       Int
  type        String
  key         String
  label       String
  placeholder String?
  required    Boolean @default(false)
  botManaged  Boolean @default(false)
  options     Json?
  translations Json?
  maxSelect   Int?    // null = unlimited; 1 = single select only

  form    ArkForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers ArkAnswer[]

  @@index([formId, order])
  @@map("ark_form_questions")
}

model ArkResponse {
  id              String   @id @default(cuid())
  formId          String
  govId           String
  govName         String
  power           BigInt?
  discordVerified Boolean  @default(false)
  submittedAt     DateTime @default(now())

  form       ArkForm         @relation(fields: [formId], references: [id])
  answers    ArkAnswer[]
  assignment ArkAssignment?

  @@unique([formId, govId])
  @@index([formId])
  @@map("ark_responses")
}

model ArkAnswer {
  id         String @id @default(cuid())
  responseId String
  questionId String
  value      Json

  response ArkResponse     @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question ArkFormQuestion @relation(fields: [questionId], references: [id])

  @@unique([responseId, questionId])
  @@map("ark_answers")
}

model ArkTeam {
  id      String @id @default(cuid())
  eventId String
  name    String
  color   String @default("#6366f1")
  order   Int

  event       ArkEvent        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignments ArkAssignment[]

  @@index([eventId])
  @@map("ark_teams")
}

model ArkAssignment {
  id           String   @id @default(cuid())
  responseId   String   @unique
  govId        String
  teamId       String?
  role         String   @default("member")
  assignedAt   DateTime @default(now())
  assignedById String?

  response ArkResponse @relation(fields: [responseId], references: [id])
  teamRef  ArkTeam?    @relation(fields: [teamId], references: [id])

  @@index([teamId])
  @@map("ark_assignments")
}

// ─── Restart Projects ──────────────────────────────────────────────────────────
// Projects that have TFN bot installed. Staff manage these in the portal.
model RestartProject {
  id               String   @id @default(cuid())
  name             String
  guildId          String   @unique  // Discord server ID where TFN bot is installed
  guildName        String
  serverLink       String?           // Discord invite link
  founderDiscordId String?           // Discord user ID of founder
  founderUsername  String?           // Discord username of founder
  targetKingdom    String?           // null / "N/A" = no target
  usesSleeper      Boolean  @default(false)
  sleeperKingdom   String?           // null / "N/A" = no starting kingdom
  active           Boolean  @default(true)
  addedById        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  applications LeadershipApplication[]

  @@map("restart_projects")
}

// ─── Leadership Applications ───────────────────────────────────────────────────
// Created by Discord bot when user opens a leadership ticket.
model LeadershipApplication {
  id                  String   @id @default(cuid())
  type                String   @default("leadership") // "founder" | "leadership"
  discordUserId       String
  discordUsername     String
  ticketChannelId     String   @unique
  projectId           String?
  isFounder           Boolean?
  screenshotUrls      Json?    // string[] of attachment URLs
  leaderPermDiscord   Boolean?
  leaderPermWebsite   Boolean?
  status              String   @default("pending") // pending | reviewing | closed | approved | denied
  discordRoleGranted  Boolean  @default(false)
  websiteRoleGranted  Boolean  @default(false)
  staffVerifiedQ2     String?  // "verified" | "denied" | null
  staffVerifiedQ3     String?
  staffVerifiedQ4     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project RestartProject? @relation(fields: [projectId], references: [id])

  @@map("leadership_applications")
}
