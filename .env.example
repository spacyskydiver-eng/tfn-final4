# ─── Next.js / Website ────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local:      postgresql://postgres:password@localhost:5432/rok_tracker
# Production: use your hosted DB URL (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://postgres:password@localhost:5432/rok_tracker"

# Base URL of this app (used in API routes for internal session lookups)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Discord OAuth ────────────────────────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
# Set redirect URI to: http://localhost:3000/api/auth/discord/callback

DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"

# Random 32-byte hex secret for signing session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET="replace_with_32_byte_hex_secret"

# ─── Optional: Production overrides ──────────────────────────────────────────

# NODE_ENV="production"
# NEXT_PUBLIC_APP_URL="https://yoursite.com"
