# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Your Discord server (guild) ID
DISCORD_GUILD_ID=your_guild_id_here

# Channel ID where staff notifications appear
DISCORD_STAFF_CHANNEL_ID=your_staff_channel_id_here

# Your website URL (for links in embeds)
APP_URL=https://your-app.vercel.app

# Internal API key for bot→website communication (set same value in website .env as BOT_API_SECRET)
BOT_API_SECRET=generate_a_random_secret_here

# Discord Client ID (Application ID from developer portal) — needed for register-commands.js
DISCORD_CLIENT_ID=your_application_id_here

# Role ID for your staff team — granted View + Send permissions in ticket channels
DISCORD_STAFF_ROLE_ID=your_staff_role_id_here

# RoK game server URL for /locate command (coord-tracking service)
ROK_SERVER_URL=http://204.168.137.204:7373
